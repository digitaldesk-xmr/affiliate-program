import { supabase } from './supabase-client.js';

export default async function handler(req, res) {
    if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

    const { affiliateId, productId, destinationUrl, customSlug } = req.body;
    if (!affiliateId) return res.status(400).json({ error: 'affiliateId required' });

    let finalDestination = destinationUrl;
    let finalProductId = productId;

    if (productId) {
        const { data: product, error: prodError } = await supabase
            .from('products')
            .select('base_url')
            .eq('id', productId)
            .single();
        if (prodError || !product) return res.status(400).json({ error: 'Invalid product' });
        if (!finalDestination) finalDestination = product.base_url;
    }

    if (!finalDestination) return res.status(400).json({ error: 'destinationUrl or productId required' });

    const { data: affiliate, error: affError } = await supabase
        .from('affiliates')
        .select('unique_code, status')
        .eq('id', affiliateId)
        .single();

    if (affError || affiliate.status !== 'active') return res.status(403).json({ error: 'Affiliate not active' });

    const linkCode = customSlug || Math.random().toString(36).substring(2, 8);
    const affiliateUrl = `https://${req.headers.host}/go/${affiliate.unique_code}/${linkCode}`;

    const { error: insertError } = await supabase
        .from('affiliate_links')
        .insert([{
            affiliate_id: affiliateId,
            product_id: finalProductId || null,
            destination_url: finalDestination,
            custom_slug: linkCode
        }]);

    if (insertError) return res.status(500).json({ error: insertError.message });

    res.json({ success: true, affiliateUrl, code: linkCode });
}