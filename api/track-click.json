import { supabase } from './supabase-client.js';

export default async function handler(req, res) {
    if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

    const { affiliateCode, linkCode, referrer, userAgent, ip } = req.body;

    const { data: link, error: linkError } = await supabase
        .from('affiliate_links')
        .select('id, affiliate_id')
        .eq('custom_slug', linkCode)
        .single();

    if (linkError || !link) return res.status(404).json({ error: 'Link not found' });

    const { data: click, error: clickError } = await supabase
        .from('clicks')
        .insert([{
            affiliate_id: link.affiliate_id,
            link_id: link.id,
            ip_address: ip || null,
            user_agent: userAgent || null,
            referrer: referrer || null
        }])
        .select()
        .single();

    if (clickError) return res.status(500).json({ error: clickError.message });

    await supabase.rpc('increment_clicks', { link_id: link.id });

    res.setHeader('Set-Cookie', `affiliate_click_id=${click.id}; Path=/; Max-Age=2592000; HttpOnly; Secure; SameSite=Lax`);
    res.json({ success: true });
}
