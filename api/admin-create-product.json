import { supabase } from './supabase-client.js';

export default async function handler(req, res) {
    if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });
    const adminKey = req.headers['x-admin-key'];
    if (adminKey !== process.env.ADMIN_API_KEY) return res.status(401).json({ error: 'Unauthorized' });

    const { name, description, default_commission_rate, base_url, is_active } = req.body;
    if (!name || !default_commission_rate || !base_url) {
        return res.status(400).json({ error: 'Missing required fields' });
    }

    const { data, error } = await supabase
        .from('products')
        .insert([{ name, description, default_commission_rate, base_url, is_active: is_active ?? true }])
        .select()
        .single();

    if (error) return res.status(500).json({ error: error.message });
    res.status(201).json({ success: true, product: data });
}
